---
import BaseLayout from '../layouts/BaseLayout.astro';

const modules = [
  {
    code: 'F-135',
    title: 'Droit de l\'assurance',
    desc: 'Agent et courtier en assurance de dommages · Expert en sinistre',
    topics: ['Contrat', 'Obligations', 'Parties', 'Sinistre', 'Résiliation', 'LDPSF'],
    questions: 100,
    available: true,
    href: '/quiz',
    examHref: '/f-135-examen',
  },
  {
    code: 'F-411',
    title: 'Assurance de biens et responsabilité civile des particuliers',
    desc: 'Agent et courtier en assurance de dommages',
    topics: ['Habitation', 'Responsabilité civile', 'Biens personnels', 'Exclusions'],
    questions: 100,
    available: false,
    href: '/f-411',
  },
  {
    code: 'F411-T3 / F511-T3',
    title: 'Assurance de biens et RC des particuliers',
    desc: 'Agent et courtier en assurance de dommages · Expert en sinistre',
    topics: ['Expertise en sinistre', 'Évaluation des dommages', 'RC particuliers'],
    questions: 100,
    available: false,
    href: '/f411-t3',
  },
  {
    code: 'F-412',
    title: 'Assurance automobile',
    desc: 'Agent et courtier en assurance de dommages',
    topics: ['Assurance auto', 'SAAQ', 'Chapitres A & B', 'Responsabilité'],
    questions: 100,
    available: false,
    href: '/f-412',
  },
];
---

<BaseLayout
  title="QuizAssurance – Preparation aux examens"
  description="QuizAssurance propose des quiz interactifs couvrant les modules de formation en assurance de dommages."
>
  <div class="landing">

    <!-- NAV -->
    <nav class="landing-nav">
      <div class="nav-brand">
        <span class="nav-logo">QuizAssurance</span>
        <span class="nav-sep">|</span>
        <span class="nav-title">Préparation aux examens</span>
      </div>
    </nav>

    <!-- HERO -->
    <section class="hero">
      <p class="hero-eyebrow">Outil de préparation</p>
      <h1 class="hero-heading">
        Choisissez votre<br />
        <span class="hero-heading-gold">module d'examen</span>
      </h1>
      <p class="hero-sub">
        Quiz interactifs couvrant les cours de formation en assurance de dommages au Québec.
        Chaque module propose 100 questions avec explications détaillées.
      </p>
    </section>

    <!-- MODULE GRID -->
    <section class="modules-grid">
      {modules.map(m => (
        <div class={`module-card${m.available ? ' available' : ' locked'}`}>
          <div class="module-top">
            <span class="module-code">{m.code}</span>
            {m.available
              ? <span class="module-badge ready">Disponible</span>
              : <span class="module-badge soon">Bientôt</span>
            }
          </div>
          <h2 class="module-title">{m.title}</h2>
          <p class="module-desc">{m.desc}</p>
          <div class="module-topics">
            {m.topics.map(t => <span class="topic-chip">{t}</span>)}
          </div>
          <div class="module-footer">
            <span class="module-count">{m.questions} questions</span>
            {m.available
              ? (
                <div class="module-actions">
                  <a href={m.href} class="module-btn module-btn-secondary">
                    Entrainement
                  </a>
                  {m.examHref && (
                    <a href={m.examHref} class="module-btn">
                      Simulation
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </a>
                  )}
                </div>
              )
              : (
                <span class="module-btn-disabled">En construction</span>
              )
            }
          </div>
        </div>
      ))}
    </section>

    <!-- FOOTER -->
    <footer class="landing-footer">
      <p>QuizAssurance · Outil de preparation non officiel en assurance de dommages</p>
    </footer>

  </div>
</BaseLayout>

<style>
  .landing {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--navy);
  }

  /* NAV */
  .landing-nav {
    padding: 20px 40px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 0.12em;
  }
  .nav-sep { color: rgba(255,255,255,0.2); font-size: 1.1rem; }
  .nav-title {
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.06em;
  }

  /* HERO */
  .hero {
    text-align: center;
    padding: 64px 40px 40px;
    max-width: 680px;
    margin: 0 auto;
    width: 100%;
  }
  .hero-eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--gold);
    margin-bottom: 16px;
  }
  .hero-heading {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 900;
    line-height: 1.1;
    color: var(--white);
    margin-bottom: 20px;
  }
  .hero-heading-gold { color: var(--gold); }
  .hero-sub {
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.55);
    max-width: 520px;
    margin: 0 auto;
  }

  /* MODULE GRID */
  .modules-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    max-width: 960px;
    margin: 48px auto 0;
    padding: 0 32px 64px;
    width: 100%;
  }
  .module-card {
    border-radius: 16px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    border: 1px solid rgba(255,255,255,0.08);
    transition: border-color 0.2s, transform 0.2s;
  }
  .module-card.available {
    background: rgba(201,168,76,0.05);
    border-color: rgba(201,168,76,0.25);
  }
  .module-card.available:hover {
    border-color: var(--gold);
    transform: translateY(-3px);
  }
  .module-card.locked {
    background: rgba(255,255,255,0.02);
    opacity: 0.7;
  }

  .module-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .module-code {
    font-family: 'Playfair Display', serif;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 0.06em;
  }
  .module-badge {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 3px 10px;
    border-radius: 20px;
  }
  .module-badge.ready {
    background: rgba(45,122,79,0.25);
    color: #6ee4a0;
    border: 1px solid rgba(45,122,79,0.4);
  }
  .module-badge.soon {
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.4);
    border: 1px solid rgba(255,255,255,0.1);
  }

  .module-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--white);
    line-height: 1.3;
  }
  .module-desc {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.5;
  }
  .module-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
  }
  .topic-chip {
    font-size: 0.68rem;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 20px;
    background: rgba(255,255,255,0.05);
    color: rgba(255,255,255,0.45);
    border: 1px solid rgba(255,255,255,0.08);
  }
  .module-card.available .topic-chip {
    background: rgba(201,168,76,0.08);
    color: rgba(201,168,76,0.7);
    border-color: rgba(201,168,76,0.15);
  }

  .module-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .module-count {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.3);
    font-weight: 500;
  }
  .module-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .module-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--gold);
    color: var(--navy);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    padding: 10px 20px;
    border-radius: 50px;
    text-decoration: none;
    transition: background 0.2s;
    letter-spacing: 0.02em;
  }
  .module-btn:hover { background: var(--gold-light); }
  .module-btn-secondary {
    background: transparent;
    color: var(--white);
    border: 1px solid rgba(255,255,255,0.18);
  }
  .module-btn-secondary:hover {
    background: rgba(255,255,255,0.08);
  }
  .module-btn-disabled {
    font-size: 0.78rem;
    font-weight: 600;
    color: rgba(255,255,255,0.2);
    font-style: italic;
  }

  /* FOOTER */
  .landing-footer {
    padding: 20px 40px;
    text-align: center;
    border-top: 1px solid rgba(255,255,255,0.06);
    margin-top: auto;
  }
  .landing-footer p {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.2);
    letter-spacing: 0.04em;
  }

  /* RESPONSIVE */
  @media (max-width: 680px) {
    .modules-grid {
      grid-template-columns: 1fr;
      padding: 0 20px 48px;
    }
    .module-footer {
      align-items: flex-start;
      flex-direction: column;
    }
    .module-actions {
      width: 100%;
      justify-content: flex-start;
    }
    .hero { padding: 48px 24px 32px; }
    .landing-nav { padding: 16px 20px; }
  }
</style>
